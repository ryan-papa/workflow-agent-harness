# .env 템플릿. 이 파일을 .env로 복사해서 값을 채운 뒤 sops로 암호화한다.
# 실제 값이 들어간 .env는 절대 커밋하지 않는다 (.gitignore 확인).
#
# 암호화: sops -e --input-type dotenv --output-type dotenv .env > .env.enc
# 복호화: sops -d --input-type dotenv --output-type dotenv .env.enc
#
# 상세: docs/security/secrets-management.md

# === DB 자격증명 ===
# MYSQL_PASSWORD=
# POSTGRES_PASSWORD=

# === 외부 API 키 ===
# EXAMPLE_API_KEY=
# EXAMPLE_CLIENT_SECRET=

# === 런타임 설정 ===
# LOG_LEVEL=INFO
# CONFIG_PATH=
